{
  "manifest_version": 3,
  "name": "Financial Report Analysis - AI Assistant",
  "version": "1.0.0",
  "description": "Financial report volatility analysis intelligent assistant, supports automated workflow execution",
  "permissions": [],
  "host_permissions": [
    "http://localhost:9000/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Financial Report Analysis"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "css": ["css/finance-copilot.css"]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
